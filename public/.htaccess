# Security Headers
Header set X-Frame-Options "DENY"
Header set X-Content-Type-Options "nosniff"
Header set Referrer-Policy "origin-when-cross-origin"

# Enable URL rewriting
RewriteEngine On

# Handle Next.js internal routing (prevent 404 on refresh)
# If the requested file or directory doesn't exist, serve the same path but with .html extension if it exists
# Or fall back to index.html for unknown routes (optional for pure static)

# Remove .html from URLs (optional but cleaner)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# For pages that are directories with index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]
